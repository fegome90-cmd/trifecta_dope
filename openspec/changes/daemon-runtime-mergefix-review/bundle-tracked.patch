diff --git a/src/infrastructure/daemon/lsp_handler.py b/src/infrastructure/daemon/lsp_handler.py
index f83d3a6c..874451f0 100644
--- a/src/infrastructure/daemon/lsp_handler.py
+++ b/src/infrastructure/daemon/lsp_handler.py
@@ -4,6 +4,51 @@ from src.domain.lsp_contracts import FallbackReason, LSPResponse
 from src.infrastructure.lsp_client import LSPState
 
 
+def _language_id_for(path: str) -> str:
+    suffix = path.rsplit(".", 1)[-1].lower() if "." in path else ""
+    return {
+        "py": "python",
+        "js": "javascript",
+        "ts": "typescript",
+    }.get(suffix, "plaintext")
+
+
+def _handle_did_open(params: dict[str, Any], lsp_client: Any) -> dict[str, Any]:
+    from pathlib import Path
+
+    path_str = params.get("path")
+    content = params.get("content", "")
+    if not isinstance(path_str, str) or not path_str:
+        return LSPResponse.error_response(
+            error_code="LSP_ERROR",
+            fallback_reason=FallbackReason.LSP_ERROR,
+            message="didOpen requires a file path",
+        ).to_dict()
+
+    path = Path(path_str).resolve()
+    payload = {"status": "notification_sent"}
+
+    if path.suffix.lower() == ".md":
+        payload["note"] = "ignored_extension=.md"
+        return LSPResponse.full_response(payload).to_dict()
+
+    lsp_client._send_rpc(
+        {
+            "jsonrpc": "2.0",
+            "method": "textDocument/didOpen",
+            "params": {
+                "textDocument": {
+                    "uri": path.as_uri(),
+                    "languageId": _language_id_for(path.name),
+                    "version": 1,
+                    "text": content,
+                }
+            },
+        }
+    )
+    return LSPResponse.full_response(payload).to_dict()
+
+
 def handle_lsp_request(req: dict[str, Any], lsp_client: Any) -> dict[str, Any]:
     """Handle JSON envelope LSP requests for daemon run."""
     method = req.get("method", "")
