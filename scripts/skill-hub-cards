#!/usr/bin/env python3
"""
skill-hub-cards: Generate skill cards for agent consumption.

Usage:
    skill-hub-cards "query" [--limit 5]

Output format is designed for agent parsing:
    # Skill: <name>
    read <path>
    Source: <source>

    <description>

Author: Trifecta Team
Date: 2026-03-19
"""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path

TRIFECTA_ROOT = Path(__file__).parent.parent
DEFAULT_SEGMENT_PATH = Path.home() / ".trifecta" / "segments" / "skills-hub"
SEGMENT_PATH = Path(os.environ.get("SKILL_HUB_SEGMENT", str(DEFAULT_SEGMENT_PATH)))


@dataclass(frozen=True)
class SkillCard:
    """Skill metadata for card rendering."""

    name: str
    path: str
    source: str
    description: str


def render_skill_card(card: SkillCard) -> str:
    """Render a single skill card."""
    lines = [
        f"# Skill: {card.name}",
        f"read {card.path}",
        f"Source: {card.source}",
        "",
    ]
    if card.description:
        lines.append(card.description)
    return "\n".join(lines)


def parse_skill_from_text(text: str, chunk_id: str) -> SkillCard | None:
    """Parse skill metadata from chunk text."""
    # Extract name from chunk_id (skill:<name>:<fingerprint>)
    parts = chunk_id.split(":")
    if len(parts) < 3 or parts[0] != "skill" or not parts[1]:
        return None
    name = parts[1]

    # Try formats: "read /path" or "**Path**: /path" or "**Read**: read /path"
    path_match = re.search(r"^\s*read\s+(.+)$", text, re.MULTILINE)
    if not path_match:
        path_match = re.search(r"^\*\*Read\*\*:\s*read\s+(.+)$", text, re.MULTILINE)
    if not path_match:
        path_match = re.search(r"^\*\*Path\*\*:\s*(.+)$", text, re.MULTILINE)

    if not path_match:
        return None

    path = path_match.group(1).strip()

    # Extract source
    source_match = re.search(r"^\*\*Source\*\*:\s*(.+)$", text, re.MULTILINE)
    source = source_match.group(1).strip() if source_match else "unknown"

    # Extract description (Use when/Use for pattern)
    desc_match = re.search(r"(?:Use when|Use for)[^\n]+(?:\n[^\n]+)*", text)
    description = desc_match.group(0).strip() if desc_match else ""

    # Clean up: remove managed-by comments
    description = re.sub(r"<!-- managed-by:[^>]+-->", "", description).strip()

    return SkillCard(name=name, path=path, source=source, description=description)


def run_search(query: str, limit: int) -> list[dict]:
    """Run trifecta ctx search with --explain."""
    import os

    cmd = [
        "uv", "run", "trifecta", "ctx", "search",
        "--segment", str(SEGMENT_PATH),
        "--query", query,
        "--limit", str(limit),
        "--explain",
    ]

    env = os.environ.copy()
    env.update({"TRIFECTA_LINT": "1", "TRIFECTA_NO_TELEMETRY": "1"})

    try:
        result = subprocess.run(
            cmd,
            cwd=str(TRIFECTA_ROOT),
            capture_output=True,
            text=True,
            env=env,
            timeout=30,
        )
    except subprocess.TimeoutExpired as e:
        stderr = e.stderr.decode() if e.stderr else ""
        stdout = e.stdout.decode() if e.stdout else ""
        print(f"skill-hub-cards: search timed out after 30s: stderr={stderr}, stdout={stdout}", file=sys.stderr)
        return []

    if result.returncode != 0:
        print(f"skill-hub-cards: search failed (rc={result.returncode}): {result.stderr.strip()}", file=sys.stderr)
        return []

    try:
        data = json.loads(result.stdout)
        return data.get("hits", [])
    except json.JSONDecodeError as e:
        print(f"skill-hub-cards: search returned invalid JSON: {e}", file=sys.stderr)
        return []


def run_get(chunk_ids: list[str]) -> dict[str, str]:
    """Run trifecta ctx get to fetch chunk texts."""
    import os

    if not chunk_ids:
        return {}

    cmd = [
        "uv", "run", "trifecta", "ctx", "get",
        "--segment", str(SEGMENT_PATH),
        "--ids", ",".join(chunk_ids),
    ]

    env = os.environ.copy()
    env.update({"TRIFECTA_LINT": "1", "TRIFECTA_NO_TELEMETRY": "1"})

    try:
        result = subprocess.run(
            cmd,
            cwd=str(TRIFECTA_ROOT),
            capture_output=True,
            text=True,
            env=env,
            timeout=30,
        )
    except subprocess.TimeoutExpired as e:
        stderr = e.stderr.decode() if e.stderr else ""
        stdout = e.stdout.decode() if e.stdout else ""
        print(f"skill-hub-cards: get timed out after 30s: stderr={stderr}, stdout={stdout}", file=sys.stderr)
        return {}

    if result.returncode != 0:
        print(f"skill-hub-cards: get failed (rc={result.returncode}): {result.stderr.strip()}", file=sys.stderr)
        return {}

    # Parse output: ## [chunk_id] title\n<content>
    chunks = {}
    current_id = None
    current_lines = []

    for line in result.stdout.split("\n"):
        if line.startswith("## [") and "]" in line:
            if current_id and current_lines:
                chunks[current_id] = "\n".join(current_lines)
            current_id = line.split("[")[1].split("]")[0]
            current_lines = []
        elif current_id:
            current_lines.append(line)

    if current_id and current_lines:
        chunks[current_id] = "\n".join(current_lines)

    return chunks


def main() -> int:
    parser = argparse.ArgumentParser(description="Generate skill cards for agent consumption.")
    parser.add_argument("query", help="Search query")
    parser.add_argument("--limit", "-l", type=int, default=5, help="Max cards (default: 5)")
    parser.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    args = parser.parse_args()
    if args.limit < 1:
        print("skill-hub-cards: --limit must be >= 1", file=sys.stderr)
        return 2

    # Validate limit argument
    if args.limit < 1:
        print(f"skill-hub-cards: --limit must be a positive integer (got {args.limit})", file=sys.stderr)
        return 1

    # Search
    hits = run_search(args.query, args.limit)
    if not hits:
        print("# No skills found", file=sys.stderr)
        return 1

    # Get full texts
    chunk_ids = [h.get("ref", "") for h in hits if h.get("ref")]
    chunk_texts = run_get(chunk_ids)

    # Parse cards
    cards = []
    for hit in hits:
        chunk_id = hit.get("ref", "")
        text = chunk_texts.get(chunk_id, "")
        if not text:
            continue

        card = parse_skill_from_text(text, chunk_id)
        if card:
            cards.append(card)

    if not cards:
        print("# No valid skill cards", file=sys.stderr)
        return 1

    # Output
    if args.json:
        data = [{"name": c.name, "path": c.path, "source": c.source, "description": c.description} for c in cards]
        print(json.dumps(data, indent=2))
    else:
        separator = "\n\n---\n\n"
        print(separator.join(render_skill_card(c) for c in cards))

    return 0


if __name__ == "__main__":
    sys.exit(main())