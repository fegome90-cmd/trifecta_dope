#!/usr/bin/env python3
"""Governed public entrypoint for skill card rendering.

This script intentionally stays thin and delegates all parsing, classification,
and rendering behavior to ``skill_hub_cards_core.py``.
"""

from __future__ import annotations

from skill_hub_cards_core import cli


def main() -> int:
    return cli()


if __name__ == "__main__":
    raise SystemExit(main())
