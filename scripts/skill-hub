#!/usr/bin/env bash
# skill-hub: Search global skills via trifecta with lightweight alias-aware reranking
# Usage: skill-hub "query"
# Example: skill-hub "refactor"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Handle help flags before processing query
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    cat << 'EOF'
Usage: skill-hub [OPTIONS] "query"

Search for skills in the global skills hub using natural language queries.

Options:
  -h, --help    Show this help message and exit
  -c, --cards   Render governed agent-friendly skill cards
  -l, --limit   Max results (default: 5)

Arguments:
  query         Natural language description of what you need
                (e.g., "refactor", "testing", "debug workflow")

Examples:
  skill-hub "refactor"
  skill-hub "how to implement TDD"
  skill-hub "docker best practices"

Environment Variables:
  SKILL_HUB_RERANK    Reranking mode: auto (default), always, never

Note:
  Multi-word queries may show a "Canonical alias match:" block
  before the normal results for better skill discovery.
EOF
    exit 0
fi

QUERY="$*"
SEGMENT="${SKILL_HUB_SEGMENT:-$HOME/.trifecta/segments/skills-hub}"
TRIFECTA_ROOT="$(dirname "$SCRIPT_DIR")"
CARDS_HELPER="$SCRIPT_DIR/skill-hub-cards"
CARDS_MODE=0
LIMIT=5
QUERY_PARTS=()

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)
            cat << 'EOF'
Usage: skill-hub [OPTIONS] "query"

Search for skills in the global skills hub using natural language queries.

Options:
  -h, --help    Show this help message and exit
  -c, --cards   Render governed agent-friendly skill cards
  -l, --limit   Max results (default: 5)

Arguments:
  query         Natural language description of what you need
                (e.g., "refactor", "testing", "debug workflow")
EOF
            exit 0
            ;;
        -c|--cards)
            CARDS_MODE=1
            shift
            ;;
        -l|--limit)
            if [ $# -lt 2 ]; then
                echo "skill-hub: --limit requires a value" >&2
                exit 2
            fi
            LIMIT="$2"
            shift 2
            ;;
        --)
            shift
            while [ $# -gt 0 ]; do
                QUERY_PARTS+=("$1")
                shift
            done
            ;;
        *)
            QUERY_PARTS+=("$1")
            shift
            ;;
    esac
done

if ! [[ "$LIMIT" =~ ^[1-9][0-9]*$ ]]; then
    echo "skill-hub: --limit must be a positive integer (got $LIMIT)" >&2
    exit 2
fi

QUERY="${QUERY_PARTS[*]}"

if [ -z "$QUERY" ]; then
    echo "Usage: skill-hub \"query\""
    echo "Example: skill-hub \"refactor\""
    echo ""
    echo "Run 'skill-hub --help' for more information."
    exit 1
fi

cd "$TRIFECTA_ROOT"

if [ "$CARDS_MODE" -eq 1 ]; then
    exec python3 "$CARDS_HELPER" "$QUERY" --limit "$LIMIT"
fi

run_search_capture() {
    local output status
    set +e
    output="$(TRIFECTA_LINT=1 uv run trifecta ctx search --segment "$SEGMENT" "$@" 2>&1)"
    status=$?
    set -e
    printf '%s' "$output"
    return "$status"
}

RERANK_MODE="${SKILL_HUB_RERANK:-auto}"
SHOULD_RERANK=0
case "$RERANK_MODE" in
  1|true|always)
    SHOULD_RERANK=1
    ;;
  0|false|never)
    SHOULD_RERANK=0
    ;;
  *)
    if [[ "$QUERY" == *" "* ]]; then
      SHOULD_RERANK=1
    fi
    ;;
esac

EXPLAIN_JSON=""
CANONICAL_ALIAS_MATCH=""
if [ "$SHOULD_RERANK" -eq 1 ] && EXPLAIN_JSON="$(TRIFECTA_LINT=1 uv run trifecta ctx search --segment "$SEGMENT" --query "$QUERY" --limit 20 --explain --explain-format json 2>/dev/null)"; then
    CANONICAL_ALIAS_MATCH="$(EXPLAIN_JSON="$EXPLAIN_JSON" python3 - <<'PY'
import json
import os
import re

try:
    data = json.loads(os.environ.get("EXPLAIN_JSON", ""))
except json.JSONDecodeError:
    print("")
    raise SystemExit(0)

expanded_terms = data.get("expansions", {}).get("expanded_terms", [])
hits = data.get("hits", [])
if not hits:
    print("")
    raise SystemExit(0)

top_ref = hits[0].get("ref", "")
for term in expanded_terms:
    if not re.fullmatch(r"[a-z0-9-]+", term):
        continue
    repo_prefix = f"repo:{term}.md:"
    for hit in hits:
        ref = hit.get("ref", "")
        if ref.startswith(repo_prefix):
            if ref != top_ref:
                print(term)
            else:
                print("")
            raise SystemExit(0)

print("")
PY
)"
fi

if [ "$SHOULD_RERANK" -eq 1 ] && [ -n "$CANONICAL_ALIAS_MATCH" ]; then
    echo "Canonical alias match: $CANONICAL_ALIAS_MATCH"
    ALIAS_OUTPUT="$(run_search_capture --query "$CANONICAL_ALIAS_MATCH" --limit 1)"
    printf '%s\n' "$ALIAS_OUTPUT"
    echo
    echo "Additional results for: $QUERY"
fi

MAIN_OUTPUT="$(run_search_capture --query "$QUERY" --limit "$LIMIT")"
printf '%s\n' "$MAIN_OUTPUT"
